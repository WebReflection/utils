{
  "name": "@webreflection/utils",
  "version": "0.3.3",
  "type": "module",
  "types": {
    "./all": "./types/all.d.ts",
    "./ascii": "./types/ascii.d.ts",
    "./bound-once": "./types/bound-once.d.ts",
    "./bound": "./types/bound.d.ts",
    "./cache": "./types/cache.d.ts",
    "./content": "./types/content.d.ts",
    "./dom-content": "./types/dom-content.d.ts",
    "./has-own": "./types/has-own.d.ts",
    "./iterable": "./types/iterable.d.ts",
    "./json-storage": "./types/json-storage.d.ts",
    "./map": "./types/map.d.ts",
    "./registry": "./types/registry.d.ts",
    "./set": "./types/set.d.ts",
    "./shared-array-buffer": "./types/shared-array-buffer.d.ts",
    "./sticky": "./types/sticky.d.ts",
    "./weakmap": "./types/weakmap.d.ts",
    "./weakset": "./types/weakset.d.ts",
    "./with-resolvers": "./types/with-resolvers.d.ts"
  },
  "exports": {
    "./all": {
      "types": "./types/all.d.ts",
      "import": "./src/all.js"
    },
    "./ascii": {
      "types": "./types/ascii.d.ts",
      "import": "./src/ascii.js"
    },
    "./bound-once": {
      "types": "./types/bound-once.d.ts",
      "import": "./src/bound-once.js"
    },
    "./bound": {
      "types": "./types/bound.d.ts",
      "import": "./src/bound.js"
    },
    "./cache": {
      "types": "./types/cache.d.ts",
      "import": "./src/cache.js"
    },
    "./content": {
      "types": "./types/content.d.ts",
      "import": "./src/content.js"
    },
    "./dom-content": {
      "types": "./types/dom-content.d.ts",
      "import": "./src/dom-content.js"
    },
    "./has-own": {
      "types": "./types/has-own.d.ts",
      "import": "./src/has-own.js"
    },
    "./iterable": {
      "types": "./types/iterable.d.ts",
      "import": "./src/iterable.js"
    },
    "./json-storage": {
      "types": "./types/json-storage.d.ts",
      "import": "./src/json-storage.js"
    },
    "./map": {
      "types": "./types/map.d.ts",
      "import": "./src/map.js"
    },
    "./registry": {
      "types": "./types/registry.d.ts",
      "import": "./src/registry.js"
    },
    "./set": {
      "types": "./types/set.d.ts",
      "import": "./src/set.js"
    },
    "./shared-array-buffer": {
      "types": "./types/shared-array-buffer.d.ts",
      "import": "./src/shared-array-buffer.js"
    },
    "./sticky": {
      "types": "./types/sticky.d.ts",
      "import": "./src/sticky.js"
    },
    "./weakmap": {
      "types": "./types/weakmap.d.ts",
      "import": "./src/weakmap.js"
    },
    "./weakset": {
      "types": "./types/weakset.d.ts",
      "import": "./src/weakset.js"
    },
    "./with-resolvers": {
      "types": "./types/with-resolvers.d.ts",
      "import": "./src/with-resolvers.js"
    },
    "./package.json": "./package.json"
  },
  "tests": [
    "all",
    "ascii",
    "bound-once",
    "bound",
    "cache",
    "dom-content",
    "has-own",
    "iterable",
    "json-storage",
    "map",
    "registry",
    "set",
    "shared-array-buffer",
    "sticky",
    "weakmap",
    "weakset",
    "with-resolvers"
  ],
  "scripts": {
    "build": "npm run build:types && npm run test",
    "build:types": "tsc --allowJs --checkJs --declaration --emitDeclarationOnly --stripInternal --outDir types --target es2022 --lib es2024 --module nodenext --moduleResolution nodenext src/*.js",
    "coverage": "mkdir -p ./coverage; c8 report --reporter=text-lcov > ./coverage/lcov.info",
    "test": "c8 node --localstorage-file './test/.storage' -e 'let q=Promise.resolve();for(const t of require(`./package.json`).tests)q=q.then(()=>import(`./test/${t}.js`));'"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "shared",
    "utility",
    "utils"
  ],
  "author": "Andrea Giammarchi",
  "license": "MIT",
  "description": "A collection of utility functions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebReflection/utils.git"
  },
  "bugs": {
    "url": "https://github.com/WebReflection/utils/issues"
  },
  "homepage": "https://webreflection.github.io/utils/",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
